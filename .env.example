VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Set to true only after Google OAuth is configured in Supabase + Google Cloud (see docs/GOOGLE_AUTH.md)
# VITE_ENABLE_GOOGLE_OAUTH=true

# Comma-separated emails allowed to use /admin (must also have profiles.role = 'admin' in Supabase)
# VITE_ADMIN_EMAILS=you@example.com

# Automated schema apply (npm run db:apply) — do NOT commit real passwords
# Option A: full connection string (recommended for CI)
# SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Option B: project ref + password (ref can be parsed from VITE_SUPABASE_URL)
# SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
# SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD
# If direct db.*.supabase.co fails (IPv6 ECONNREFUSED), use Session pooler from Dashboard:
# Session pooler (IPv4) — see Dashboard → Database → Connection string → Session pooler
# SUPABASE_DB_POOLER_HOST=aws-1-us-east-2.pooler.supabase.com
# SUPABASE_DB_POOLER_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# Or set POOLER_HOST + PROJECT_REF + DB_PASSWORD only (script builds the URI)
